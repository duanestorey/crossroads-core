<!DOCTYPE html>
<html lang="{$site->lang}">
    <head>
        <meta charset="{$site->charset}">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="generator" content="Crossroads SSG">

        <title>{$page->title}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap">

        <link rel="stylesheet" href="{$page->assetUrl}/phosphor.css?v={$page->assetHash}">

        {if $isSingle}
        <link rel="canonical" href="{$content->url}">
        <meta name="description" content="{$content->description}">
        <meta property="og:description" content="{$content->description}">
        <meta property="og:title" content="{$page->title}">
        <meta property="og:url" content="{$content->url}">
        <meta property="og:type" content="article">
        {if $content->featuredImageData}
        <meta property="og:image" content="{$content->featuredImageData->public_url}">
        <meta property="og:image:width" content="{$content->featuredImageData->width}">
        <meta property="og:image:height" content="{$content->featuredImageData->height}">
        {/if}
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{$page->title}">
        <meta name="twitter:description" content="{$content->description}">
        {if $content->featuredImageData}
        <meta name="twitter:image" content="{$content->featuredImageData->public_url}">
        {/if}
        {else}
        <meta name="description" content="{$page->description}">
        <meta property="og:description" content="{$page->description}">
        {/if}
    </head>
    <body class="{$page->bodyClasses}">
        <header class="site-header">
            <div class="container header-inner">
                <a href="/" class="site-title">$ {$site->title}<span class="cursor"></span></a>
                <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">[=]</button>
                <nav class="nav-links">
                    {foreach $menu['main'] as $menu_item}
                    <a href="{$menu_item->url}"{if $menu_item->isActive} class="active"{/if}>{$menu_item->name}</a>
                    {/foreach}
                </nav>
            </div>
        </header>

        <main>
            <div class="container page-layout">
                {include 'sidebar.latte'}
                <div class="page-content">
