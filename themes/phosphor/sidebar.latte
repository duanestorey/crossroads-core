                <aside class="sidebar">
                    <div class="sidebar-section">
                        <div class="sidebar-heading">// about</div>
                        <p>{$site->bio}</p>
                    </div>

                    <div class="sidebar-section">
                        <div class="sidebar-heading">// navigate</div>
                        <ul class="sidebar-nav">
                            {foreach $menu['main'] as $menu_item}
                            <li><a href="{$menu_item->url}"{if $menu_item->isActive} class="active"{/if}>{$menu_item->name}</a></li>
                            {/foreach}
                        </ul>
                    </div>

                    {if count($site->social)}
                    <div class="sidebar-section">
                        <div class="sidebar-heading">// elsewhere</div>
                        <ul class="sidebar-nav">
                            {foreach $site->social as $name => $url}
                            <li><a href="{$url}">{$name}</a></li>
                            {/foreach}
                        </ul>
                    </div>
                    {/if}
                </aside>
